# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# MongoDB
MONGO_URI=mongodb://localhost:27017/main_backend

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# Auth
OTP_SECRET=your-otp-secret
FRONTEND_URL=http://localhost:5173

# Rate Limit
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Captcha Service
CAPTCHA_SERVICE_URL=
CAPTCHA_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=dev

# Cryptomus
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
